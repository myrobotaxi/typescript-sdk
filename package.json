{
  "name": "typescript-sdk-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "MyRoboTaxi TypeScript SDK monorepo root (npm workspaces).",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint .",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.39.3",
    "typescript-eslint": "^8.18.0",
    "typescript": "^5.7.0"
  }
}
